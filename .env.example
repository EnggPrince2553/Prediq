# Prediq — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit your actual .env file (it is already in .gitignore).

# ─── Formspree (waitlist email collection) ────────────────────────────────────
# 1. Sign up free at https://formspree.io
# 2. Create a new form → copy the endpoint URL (looks like: https://formspree.io/f/abcd1234)
# 3. Paste it here, then redeploy.
VITE_FORMSPREE_URL=https://formspree.io/f/YOUR_FORM_ID

# ─── Google Analytics ──────────────────────────────────────────────────────────
# 1. Go to https://analytics.google.com
# 2. Admin → Data Streams → your stream → Measurement ID (starts with G-)
# 3. Replace G-XXXXXXXXXX in index.html with your real ID.
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
